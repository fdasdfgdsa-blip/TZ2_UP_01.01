<Window x:Class="LearningPlatform.App.CourseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Курс" Height="600" Width="900" Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и прогресс -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock x:Name="TitleText" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
            <ProgressBar x:Name="CourseProgress" Height="10" Margin="0,10,0,0" Foreground="#27AE60"/>
            <TextBlock x:Name="ProgressLabel" Text="Прогресс: 0%" Foreground="#7F8C8D" Margin="0,5,0,0"/>
        </StackPanel>

        <TabControl Grid.Row="1" BorderThickness="0">
            <!-- Вкладка 1: Уроки -->
            <TabItem Header="Уроки (Лекции)">
                <ListView x:Name="LessonsList" Background="Transparent" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Padding="15" Margin="5" BorderBrush="#EEE" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Topic}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <Button Grid.Column="1" Content="Открыть" Click="OpenLesson_Click" Tag="{Binding Id}" Padding="15,5" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </TabItem>

            <!-- Вкладка 2: Задания -->
            <TabItem Header="Задания">
                <ListView x:Name="AssignmentsList" Background="Transparent" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Padding="15" Margin="5" BorderBrush="#EEE" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Description}" Foreground="#666" FontSize="11"/>
                                        <TextBlock Text="{Binding Type, StringFormat='Тип: {0}'}" Foreground="#888" FontSize="11"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Выполнить" Click="OpenAssignment_Click" Tag="{Binding Id}" Padding="15,5" Background="#27AE60" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </TabItem>

            <!-- Вкладка 3: Пользователи -->
            <TabItem Header="Пользователи">
                <Grid Margin="10">
                    <ListView x:Name="UsersList" Background="Transparent" BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Имя" DisplayMemberBinding="{Binding Username}" Width="200"/>
                                <GridViewColumn Header="Роль" DisplayMemberBinding="{Binding Role}" Width="150"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- Вкладка 4: Отчет -->
            <TabItem Header="Отчет">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Итоговый отчет по курсу" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                        <Border Background="White" Padding="20" BorderBrush="#DDD" BorderThickness="1">
                            <StackPanel>
                                <TextBlock x:Name="ReportCourseName" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock x:Name="ReportStudentName" Margin="0,0,0,5"/>
                                <TextBlock x:Name="ReportProgress" Margin="0,0,0,5"/>
                                <TextBlock x:Name="ReportFinalScore" FontWeight="Bold" Foreground="#27AE60" Margin="0,0,0,15"/>
                                <TextBlock Text="Сертификат:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <Border Background="#F9F9F9" Padding="10" BorderBrush="#EEE" BorderThickness="1">
                                    <TextBlock x:Name="ReportCertificateText" TextWrapping="Wrap" FontFamily="Consolas"/>
                                </Border>
                                <Button Content="Скачать отчет" Click="DownloadReport_Click" 
                                        HorizontalAlignment="Left" Margin="0,20,0,0" 
                                        Padding="20,8" Background="#3498DB" Foreground="White" 
                                        BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Button Grid.Row="2" Content="Закрыть" HorizontalAlignment="Right" Padding="20,8" Margin="0,15,0,0" Click="Close_Click" Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
    </Grid>
</Window>