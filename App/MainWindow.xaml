<Window x:Class="LearningPlatform.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Образовательная Платформа" Height="600" Width="900" Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Меню навигации -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="White" Height="50">
            <Button Content="Каталог курсов" Click="TabCatalog_Click" Padding="20,0" BorderThickness="0" Background="Transparent" FontWeight="Bold"/>
            <Button Content="Мои курсы" Click="TabMyCourses_Click" Padding="20,0" BorderThickness="0" Background="Transparent" FontWeight="Bold"/>
            <Button Content="Пользователи" Click="TabUsers_Click" Padding="20,0" BorderThickness="0" Background="Transparent" FontWeight="Bold"/>
        </StackPanel>

        <!-- Область контента -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Панель Каталога -->
                <WrapPanel x:Name="CatalogPanel" Margin="10"/>

                <!-- Панель Моих Курсов -->
                <WrapPanel x:Name="MyCoursesPanel" Margin="10" Visibility="Collapsed"/>

                <!-- Панель Пользователей (Только Имя и Роль) -->
                <ListView x:Name="UsersPanel" Margin="20" Visibility="Collapsed" Background="Transparent" BorderThickness="0">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Имя пользователя" DisplayMemberBinding="{Binding Username}" Width="300"/>
                            <GridViewColumn Header="Роль" DisplayMemberBinding="{Binding Role}" Width="150"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>