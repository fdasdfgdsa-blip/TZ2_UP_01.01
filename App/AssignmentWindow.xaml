<Window x:Class="LearningPlatform.App.AssignmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задание" Height="480" Width="650" Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

        <!-- Блок с переносом текста -->
        <Border Grid.Row="1" Background="#E8F6F3" Padding="12" Margin="0,0,0,15">
            <TextBlock x:Name="TypeInfo" Foreground="#16A085" FontSize="14" FontWeight="SemiBold" 
                       TextWrapping="Wrap" LineHeight="20"/>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
            <TextBlock x:Name="DescText" TextWrapping="Wrap" FontSize="13" LineHeight="18"/>
        </ScrollViewer>

        <StackPanel Grid.Row="3">
            <TextBlock Text="Ваша оценка (2-5):" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="13"/>
            <TextBox x:Name="GradeInput" FontSize="16" Padding="8" MaxLength="1" Margin="0,0,0,10"/>
            <TextBlock x:Name="WarningText" Foreground="Red" FontSize="11" Margin="0,5,0,0" Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Сдать" Click="Submit_Click" Padding="20,8" Margin="0,0,10,0" Background="#3498DB" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Отмена" Click="Cancel_Click" Padding="20,8" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>