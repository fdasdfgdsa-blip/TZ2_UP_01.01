<Window x:Class="LearningPlatform.App.LessonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лекция" Height="500" Width="800" Background="#F9F9F9">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- ScrollViewer обернут в Border для поддержки CornerRadius -->
        <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5">
            <ScrollViewer x:Name="LectureScroll" VerticalScrollBarVisibility="Auto" Padding="15" ScrollChanged="LectureScroll_ScrollChanged">
                <TextBlock x:Name="ContentText" TextWrapping="Wrap" LineHeight="22" FontSize="15"/>
            </ScrollViewer>
        </Border>

        <Button x:Name="CompleteBtn" Grid.Row="2" Content="Отметить как пройденный" HorizontalAlignment="Right" 
                Padding="20,10" Margin="0,15,0,0" Background="#27AE60" Foreground="White" BorderThickness="0" 
                Cursor="Hand" Visibility="Collapsed" Click="CompleteBtn_Click"/>
    </Grid>
</Window>